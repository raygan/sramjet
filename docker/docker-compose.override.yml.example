# Copy this file to docker-compose.override.yml to customize your deployment.
# Docker Compose merges it automatically with docker-compose.yml.
# The override file is gitignored so your local settings are never committed.
services:
  sramjet:
    ports:
      - "8080:8080"    # Change the host port if 8080 is taken
    volumes:
      - /path/to/your/data:/data    # Absolute path to your data directory
    environment:
      - DISPLAY_TZ=America/Chicago  # Your local timezone
